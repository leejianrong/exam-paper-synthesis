{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exam-paper-synthesis/schemas/canonical-question.schema.json",
  "title": "Canonical Question Object",
  "description": "The single source of truth for one question (generated or sourced). Rendered worksheet/answer-key/diagram are views of this object. See docs/SCHEMA.md and ADR-0004/0012/0013/0014.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "source_type", "syllabus", "cognitive", "question", "provenance"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver of this schema; validated on load."
    },
    "id": { "type": "string", "minLength": 1 },
    "source_type": {
      "type": "string",
      "enum": ["generated", "sourced"],
      "description": "generated = from a blueprint+solver; sourced = ingested externally."
    },
    "blueprint_code": {
      "type": ["string", "null"],
      "description": "Required for generated questions; null for sourced."
    },
    "seed": { "type": ["integer", "null"] },
    "syllabus": { "$ref": "#/$defs/syllabus" },
    "cognitive": { "$ref": "#/$defs/cognitive" },
    "parameters": {
      "type": ["object", "null"],
      "description": "Sampled inputs for generated questions; must validate against the blueprint's declared parameter schema (ADR-0014). Null for sourced."
    },
    "question": { "$ref": "#/$defs/question" },
    "source": { "$ref": "#/$defs/source" },
    "license": { "type": ["string", "null"] },
    "validation": { "$ref": "#/$defs/validation" },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "allOf": [
    {
      "$comment": "Generated questions must name a blueprint and parameters.",
      "if": { "properties": { "source_type": { "const": "generated" } } },
      "then": { "required": ["blueprint_code", "parameters"], "properties": {
        "blueprint_code": { "type": "string" },
        "parameters": { "type": "object" }
      } }
    },
    {
      "$comment": "Sourced questions must carry provenance source + license.",
      "if": { "properties": { "source_type": { "const": "sourced" } } },
      "then": { "required": ["source", "license"], "properties": {
        "source": { "type": "object" },
        "license": { "type": "string" }
      } }
    }
  ],

  "$defs": {
    "syllabus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "strand", "topic", "skill_codes"],
      "properties": {
        "level": { "type": "string", "enum": ["P5", "P6"], "$comment": "MVP scope; extend for Sec/O-Level later." },
        "strand": { "type": "string" },
        "topic": { "type": "string" },
        "subtopic": { "type": ["string", "null"] },
        "skill_codes": { "type": "array", "items": { "type": "string" } }
      }
    },

    "cognitive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["difficulty", "cognitive_level"],
      "properties": {
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "cognitive_level": {
          "type": "string",
          "enum": ["routine_procedural", "complex_familiar", "non_routine_heuristic"]
        },
        "heuristics": { "type": "array", "items": { "type": "string" } },
        "representations": { "type": "array", "items": { "type": "string" } },
        "difficulty_levers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Which difficulty levers this question employs (see docs/DIFFICULTY.md / ADR-0015)."
        }
      }
    },

    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parts", "total_marks"],
      "properties": {
        "stem": { "type": ["string", "null"], "description": "Optional shared lead-in for multi-part questions." },
        "parts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/part" } },
        "total_marks": { "type": "integer", "minimum": 0 }
      }
    },

    "part": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "text", "marks", "answer", "marking_scheme", "solution_steps"],
      "properties": {
        "label": { "type": "string", "description": "e.g. 'a', 'b', 'c'. Use 'a' (or '') for single-part." },
        "text": { "type": "string", "minLength": 1 },
        "marks": { "type": "integer", "minimum": 0 },
        "answer": { "$ref": "#/$defs/answer" },
        "marking_scheme": { "type": "array", "items": { "$ref": "#/$defs/mark" } },
        "solution_steps": { "type": "array", "items": { "$ref": "#/$defs/step" } },
        "diagram": { "oneOf": [ { "type": "null" }, { "$ref": "#/$defs/diagram" } ] }
      }
    },

    "mark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mark", "type", "description"],
      "properties": {
        "mark": { "type": "integer", "minimum": 1 },
        "type": { "type": "string", "enum": ["M", "A", "B"], "description": "M=method, A=accuracy, B=independent." },
        "description": { "type": "string" }
      }
    },

    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string" },
        "expr": { "type": ["string", "null"], "description": "Optional machine-checkable expression for verification." }
      }
    },

    "unit": {
      "type": "string",
      "$comment": "Controlled vocabulary (ADR-0013/0014). Extend deliberately.",
      "enum": ["", "cm", "m", "km", "mm", "cm^2", "m^2", "cm^3", "m^3", "ml", "l", "g", "kg", "$", "cents", "%", "degrees", "s", "min", "h", "km/h", "m/s", "m/min", "marbles", "items", "people", "units"]
    },

    "answer": {
      "description": "Discriminated union keyed by `type` (ADR-0013).",
      "oneOf": [
        { "$ref": "#/$defs/answer_integer" },
        { "$ref": "#/$defs/answer_decimal" },
        { "$ref": "#/$defs/answer_fraction" },
        { "$ref": "#/$defs/answer_ratio" },
        { "$ref": "#/$defs/answer_quantity" },
        { "$ref": "#/$defs/answer_set" },
        { "$ref": "#/$defs/answer_text" }
      ]
    },
    "answer_integer": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "integer" },
        "value": { "type": "integer" },
        "unit": { "$ref": "#/$defs/unit" }
      }
    },
    "answer_decimal": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "decimal" },
        "value": { "type": "number" },
        "dp": { "type": ["integer", "null"], "minimum": 0, "description": "Required decimal places, if constrained." },
        "unit": { "$ref": "#/$defs/unit" }
      }
    },
    "answer_fraction": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "numerator", "denominator"],
      "properties": {
        "type": { "const": "fraction" },
        "numerator": { "type": "integer" },
        "denominator": { "type": "integer", "not": { "const": 0 } },
        "mixed": { "type": "boolean", "default": false },
        "unit": { "$ref": "#/$defs/unit" }
      }
    },
    "answer_ratio": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "parts"],
      "properties": {
        "type": { "const": "ratio" },
        "parts": { "type": "array", "minItems": 2, "items": { "type": "integer", "minimum": 0 } }
      }
    },
    "answer_quantity": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "value", "unit"],
      "properties": {
        "type": { "const": "quantity" },
        "value": { "type": "number" },
        "unit": { "$ref": "#/$defs/unit" }
      }
    },
    "answer_set": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "values"],
      "properties": {
        "type": { "const": "set" },
        "values": { "type": "array", "minItems": 1, "items": { "type": ["number", "string"] } },
        "ordered": { "type": "boolean", "default": false }
      }
    },
    "answer_text": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "text" },
        "text": { "type": "string" }
      }
    },

    "diagram": {
      "description": "Discriminated union keyed by `type` (ADR-0012).",
      "oneOf": [
        { "$ref": "#/$defs/diagram_bar_model" },
        { "$ref": "#/$defs/diagram_bar_model_before_after" },
        { "$ref": "#/$defs/diagram_geometry_figure" },
        { "$ref": "#/$defs/diagram_shaded_fraction" },
        { "$ref": "#/$defs/diagram_raster" }
      ]
    },
    "diagram_bar_model": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "bars"],
      "properties": {
        "type": { "const": "bar_model" },
        "bars": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["label", "units"],
            "properties": {
              "label": { "type": "string" },
              "units": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "annotations": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["label"],
            "properties": {
              "from_unit": { "type": "integer", "minimum": 0 },
              "to_unit": { "type": "integer", "minimum": 0 },
              "label": { "type": "string" }
            }
          }
        },
        "total_bracket": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["label"],
          "properties": { "label": { "type": "string" } },
          "$comment": "Vertical curly brace spanning all bars, labelling the total (added in schema 1.1.0)."
        }
      }
    },
    "diagram_bar_model_before_after": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "stages"],
      "$comment": "Before-after ratio aid: two stages of bars sharing a unit scale (added in schema 1.2.0). The optional per-bar `parts` (original ratio-term count that a bar's equalised `units` represent) and `view_mode` (grouped|sliced) drive the two KAN-310 render modes; both are additive and arrived in schema 1.4.0 (alongside the geometry segment `dashed` field). Coprime-ish ratios blow up the common-unit LCM, so `view_mode` defaults to \"grouped\": bars drawn at original-ratio granularity with a per-segment unit-worth label (never explodes). \"sliced\" keeps the common-unit grid with heavy dividers on the original-ratio boundaries. `parts` is display-only (the answer is unchanged); the consistency check verifies it against the ratio terms when present.",
      "properties": {
        "type": { "const": "bar_model_before_after" },
        "view_mode": {
          "enum": ["grouped", "sliced"],
          "default": "grouped",
          "$comment": "Render mode (KAN-310, schema 1.4.0). Default \"grouped\"."
        },
        "stages": {
          "type": "array", "minItems": 2, "maxItems": 2,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["name", "bars"],
            "properties": {
              "name": { "type": "string" },
              "bars": {
                "type": "array", "minItems": 1,
                "items": {
                  "type": "object", "additionalProperties": false,
                  "required": ["label", "units"],
                  "properties": {
                    "label": { "type": "string" },
                    "units": { "type": "integer", "minimum": 0 },
                    "parts": {
                      "type": "integer", "minimum": 1,
                      "$comment": "Original ratio-term count this bar's `units` represent (KAN-310, schema 1.4.0). Each drawn segment is worth `units / parts` common units."
                    }
                  }
                }
              }
            }
          }
        },
        "annotations": {
          "type": "array",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["label"],
            "properties": {
              "from_unit": { "type": "integer", "minimum": 0 },
              "to_unit": { "type": "integer", "minimum": 0 },
              "label": { "type": "string" }
            }
          }
        },
        "total_bracket": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["label"],
          "properties": { "label": { "type": "string" } },
          "$comment": "Vertical curly brace on the invariant person's bar, labelling their amount."
        }
      }
    },
    "diagram_geometry_figure": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "unit", "points"],
      "$comment": "General 2D figure (added in schema 1.3.0). Covers both PSLE geometry families: angle figures (points + segments + angle marks) and area/perimeter figures (+ arcs + shaded regions + dimension labels). Supersedes the never-built composite_geometry + area_perimeter types. Coordinates are figure-space floats scaled into a fixed viewBox by the renderer; labelled values are exact (from params, never measured off the drawing). See docs/shaping/V6b-geometry-plan.md.",
      "properties": {
        "type": { "const": "geometry_figure" },
        "unit": { "$ref": "#/$defs/unit", "$comment": "For length/area labels; angles are unitless degrees." },
        "points": {
          "type": "array", "minItems": 2,
          "description": "Named vertices in figure coordinates.",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "x", "y"],
            "properties": {
              "id": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          }
        },
        "segments": {
          "type": "array",
          "description": "Straight edges between named points; optional length label and equal-side tick marks.",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "label": { "type": ["string", "null"] },
              "ticks": { "type": "integer", "minimum": 0 },
              "dashed": { "type": "boolean", "default": false }
            }
          }
        },
        "arcs": {
          "type": "array",
          "description": "Circular arcs (whole/semi/quarter circles) centred on a named point.",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["center", "radius", "start_deg", "end_deg"],
            "properties": {
              "center": { "type": "string" },
              "radius": { "type": "number", "exclusiveMinimum": 0 },
              "start_deg": { "type": "number" },
              "end_deg": { "type": "number" },
              "label": { "type": ["string", "null"] }
            }
          }
        },
        "angles": {
          "type": "array",
          "description": "Angle marks at a named vertex, swept from one ray to another. Exactly one may be the unknown to solve.",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["at", "from", "to"],
            "properties": {
              "at": { "type": "string" },
              "from": { "type": "string" },
              "to": { "type": "string" },
              "value_deg": { "type": ["number", "null"] },
              "unknown": { "type": "boolean", "default": false },
              "right": { "type": "boolean", "default": false }
            }
          }
        },
        "shaded": {
          "type": ["array", "null"],
          "description": "Region(s) to fill, each a boundary of named points optionally closed by arcs.",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["boundary"],
            "properties": {
              "boundary": { "type": "array", "minItems": 3, "items": { "type": "string" } },
              "arcs": { "type": "array" }
            }
          }
        },
        "labels": {
          "type": "array",
          "description": "Free text labels anchored at a named point.",
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["at", "text"],
            "properties": {
              "at": { "type": "string" },
              "text": { "type": "string" }
            }
          }
        }
      }
    },
    "diagram_shaded_fraction": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "total_parts", "shaded_parts", "shape"],
      "properties": {
        "type": { "const": "shaded_fraction" },
        "shape": { "type": "string", "enum": ["rectangle", "circle", "bar"] },
        "total_parts": { "type": "integer", "minimum": 1 },
        "shaded_parts": { "type": "integer", "minimum": 0 }
      }
    },
    "diagram_raster": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "asset_ref", "alt_text"],
      "properties": {
        "type": { "const": "raster" },
        "asset_ref": { "type": "string", "description": "Path/URI to the image (sourced diagrams)." },
        "alt_text": { "type": "string" }
      }
    },

    "source": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "description": "Citation for sourced questions.",
      "properties": {
        "origin": { "type": "string", "description": "e.g. school name, assessment book title." },
        "year": { "type": ["integer", "null"] },
        "paper": { "type": ["string", "null"] },
        "reference": { "type": ["string", "null"] }
      }
    },

    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail", "unverified"] },
        "checks": {
          "type": "object",
          "description": "Per-check booleans/notes, e.g. answer_verified, unique, diagram_consistent, within_level.",
          "additionalProperties": { "type": ["boolean", "string", "null"] }
        }
      }
    },

    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_by", "version"],
      "properties": {
        "created_by": { "type": "string", "enum": ["engine", "ingested"] },
        "llm_used": { "type": "boolean", "default": false },
        "created_at": { "type": ["string", "null"], "description": "ISO-8601 timestamp; nullable." },
        "parent_id": { "type": ["string", "null"], "description": "Lineage: the object this was edited from." },
        "version": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
