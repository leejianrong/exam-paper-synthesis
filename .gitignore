# Claude Code local (machine-specific) settings
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# uv
.uv/
# uv.lock IS committed (reproducible workspace) — do not ignore it.

# Env / secrets (Vite reads .env*; keep an .env.example tracked)
.env
.env.*
!.env.example

# Node / Vite / Svelte
node_modules/
web/dist/
.svelte-kit/

# Background-subagent worktrees (temporary)
.claude/worktrees/

# Local-only reference material: the MOE syllabus is copyrighted (personal /
# non-commercial reproduction only) and this repo is PUBLIC, so the source files
# are kept local and never committed. Only the folder's README is tracked.
docs/syllabus/*
!docs/syllabus/README.md

# Playwright / generated exports
playwright-report/
test-results/
*.pdf

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
